# Copy to .env and fill in real values. .env is gitignored; this template is NOT.
# Never put real secrets in this file.

# --- Model (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Observability: LangSmith (optional but recommended) ---
# LangChain auto-traces when these are set. Get a key at https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=vera

# --- Persistence: LangGraph checkpoint store (Postgres) ---
# If set, conversation state survives restarts. Use the same Postgres as Supabase
# (Project Settings -> Database -> Connection string, with ?sslmode=require) or
# a dedicated instance. If unset, state is in-memory (lost on restart).
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require

# --- Persistence: application data (Supabase) ---
# If both are set, applications are stored in Supabase; otherwise in memory.
# Run database/schema.sql once, then set these.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# --- Auth: Supabase Auth (invite-only accounts) ---
# JWT secret verifies access tokens. Supabase dashboard: Project Settings ->
# API -> JWT Settings -> JWT Secret. If unset, auth is DISABLED (dev only).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Where the invitation email sends the user to set their password (your frontend).
VERA_AUTH_REDIRECT_URL=https://your-frontend/set-password

# --- Bootstrap: platform super_admin (run once) ---
# Used only by `python -m vera.auth.seed_super_admin` to create the first
# platform admin out-of-band. Not read at runtime.
VERA_SUPERADMIN_EMAIL=you@yourcompany.com
VERA_SUPERADMIN_PASSWORD=choose-a-strong-password

# --- App settings (optional; defaults shown) ---
# VERA_MODEL=claude-sonnet-4-6
# VERA_MAX_TOKENS=1024
# VERA_MAX_STEPS=8
# VERA_API_KEY=set-to-require-api-auth  (unset = no auth)

# --- Observability: OpenTelemetry (optional, Grafana Cloud / OTLP) ---
# Uncomment and configure to send traces, metrics, and logs to Grafana Cloud.
# Get the endpoint and base64 token from Grafana Cloud -> OTLP details.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-grpc.<region>.grafana.net:4317
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance-id:api-key)>
# OTEL_SERVICE_NAME=vera
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
